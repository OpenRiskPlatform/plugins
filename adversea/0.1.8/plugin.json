{
    "$schema": "../../schemas/plugin-manifest.schema.json",
    "id": "adversea",
    "version": "0.1.8",
    "name": "Adversea",
    "description": "Full Adversea integration covering all documented screening, entity recognition, and account endpoints.",
    "authors": [
        {
            "name": "OpenRiskPlatform",
            "email": "example@openrisk.platform"
        }
    ],
    "icon": "icon.png",
    "license": "MIT",
    "main": "index.ts",
    "entrypoints": [
        {
            "id": "pep-sanctions",
            "name": "PEP & Sanctions Check",
            "description": "Checks PEP exposure and active sanctions datasets for the target name.",
            "function": "pepSanctionsCheck",
            "inputs": [
                {
                    "name": "target",
                    "type": "string",
                    "optional": false,
                    "title": "Target Name",
                    "description": "Full name of the person or organization to screen."
                },
                {
                    "name": "force_recreate",
                    "type": "boolean",
                    "optional": true,
                    "title": "Force Recreate",
                    "description": "Bypass cache and refresh all response parts.",
                    "default": false
                }
            ]
        },
        {
            "id": "topic-report",
            "name": "Topic Report",
            "description": "Adverse media analysis grouped by risk topics.",
            "function": "topicReport",
            "inputs": [
                {
                    "name": "target",
                    "type": "string",
                    "optional": false,
                    "title": "Target Name",
                    "description": "Full name of the person or organization to screen."
                },
                {
                    "name": "output_language",
                    "type": {
                        "name": "enum",
                        "values": [
                            "English",
                            "Slovak"
                        ]
                    },
                    "optional": true,
                    "title": "Output Language",
                    "description": "Language for generated text output.",
                    "default": "English"
                },
                {
                    "name": "country",
                    "type": {
                        "name": "enum",
                        "values": [
                            "usa",
                            "australia",
                            "new_zealand",
                            "great_britain",
                            "germany",
                            "czechia",
                            "slovakia",
                            "italy",
                            "austria",
                            "belgium",
                            "bulgaria",
                            "croatia",
                            "cyprus",
                            "denmark",
                            "estonia",
                            "finland",
                            "france",
                            "greece",
                            "hungary",
                            "ireland",
                            "latvia",
                            "lithuania",
                            "luxembourg",
                            "malta",
                            "netherlands",
                            "poland",
                            "portugal",
                            "romania",
                            "slovenia",
                            "spain",
                            "sweden"
                        ]
                    },
                    "optional": true,
                    "title": "Country",
                    "description": "Country of origin of websites used for screening. Increases accuracy."
                },
                {
                    "name": "force_recreate",
                    "type": "boolean",
                    "optional": true,
                    "title": "Force Recreate",
                    "description": "Bypass cache and refresh all response parts.",
                    "default": false
                }
            ]
        },
        {
            "id": "social-media",
            "name": "Social Media",
            "description": "Finds public social media profiles matching the target name.",
            "function": "socialMediaCheck",
            "inputs": [
                {
                    "name": "target",
                    "type": "string",
                    "optional": false,
                    "title": "Target Name",
                    "description": "Full name of the person or organization to screen."
                },
                {
                    "name": "force_recreate",
                    "type": "boolean",
                    "optional": true,
                    "title": "Force Recreate",
                    "description": "Bypass cache and refresh all response parts.",
                    "default": false
                }
            ]
        },
        {
            "id": "unit-analysis",
            "name": "Unit Analysis",
            "description": "Analyzes search engine results for each URL. Mode text returns concise text; mode claims returns atomic facts.",
            "function": "unitAnalysis",
            "inputs": [
                {
                    "name": "target",
                    "type": "string",
                    "optional": false,
                    "title": "Target Name",
                    "description": "Name of the screened person or company."
                },
                {
                    "name": "mode",
                    "type": {
                        "name": "enum",
                        "values": [
                            "text",
                            "claims"
                        ]
                    },
                    "optional": true,
                    "title": "Mode",
                    "description": "text = concise analysis per URL; claims = atomic facts per URL.",
                    "default": "text"
                },
                {
                    "name": "output_language",
                    "type": {
                        "name": "enum",
                        "values": [
                            "English",
                            "Slovak"
                        ]
                    },
                    "optional": true,
                    "title": "Output Language",
                    "description": "Language for generated text.",
                    "default": "English"
                },
                {
                    "name": "country",
                    "type": {
                        "name": "enum",
                        "values": [
                            "usa",
                            "australia",
                            "new_zealand",
                            "great_britain",
                            "germany",
                            "czechia",
                            "slovakia",
                            "italy",
                            "austria",
                            "belgium",
                            "bulgaria",
                            "croatia",
                            "cyprus",
                            "denmark",
                            "estonia",
                            "finland",
                            "france",
                            "greece",
                            "hungary",
                            "ireland",
                            "latvia",
                            "lithuania",
                            "luxembourg",
                            "malta",
                            "netherlands",
                            "poland",
                            "portugal",
                            "romania",
                            "slovenia",
                            "spain",
                            "sweden"
                        ]
                    },
                    "optional": true,
                    "title": "Country",
                    "description": "Country of origin of websites used for screening. Increases accuracy."
                },
                {
                    "name": "media_only",
                    "type": "boolean",
                    "optional": true,
                    "title": "Media Only",
                    "description": "Restrict analysis to internet media.",
                    "default": false
                },
                {
                    "name": "force_recreate",
                    "type": "boolean",
                    "optional": true,
                    "title": "Force Recreate",
                    "description": "Bypass cache and refresh all response parts.",
                    "default": false
                }
            ]
        },
        {
            "id": "rpo",
            "name": "RPO Organization Search (Slovakia only)",
            "description": "Finds Slovak organizations in RPO/ORSR registry. Automatically fetches business subjects for each found organization. Slovakia only.",
            "function": "rpoSearch",
            "inputs": [
                {
                    "name": "target",
                    "type": "string",
                    "optional": false,
                    "title": "Target Name",
                    "description": "Name of person or company to search in RPO."
                },
                {
                    "name": "force_recreate",
                    "type": "boolean",
                    "optional": true,
                    "title": "Force Recreate",
                    "description": "Bypass cache and refresh all response parts.",
                    "default": false
                }
            ]
        },
        {
            "id": "debtors",
            "name": "Debtors Check (Slovakia only)",
            "description": "Checks publicly available debtor registries (health insurance, tax authority, etc.) for the target. Slovakia only.",
            "function": "debtorCheck",
            "inputs": [
                {
                    "name": "target",
                    "type": "string",
                    "optional": false,
                    "title": "Target Name",
                    "description": "Name of person or company to screen in debtor lists."
                },
                {
                    "name": "force_recreate",
                    "type": "boolean",
                    "optional": true,
                    "title": "Force Recreate",
                    "description": "Bypass cache and refresh all response parts.",
                    "default": false
                }
            ]
        },
        {
            "id": "default-entity-recognition",
            "name": "Default Entity Recognition",
            "description": "Extracts related entities (people, companies) from search results for the target name. Useful for discovering connections.",
            "function": "defaultEntityRecognition",
            "inputs": [
                {
                    "name": "target",
                    "type": "string",
                    "optional": false,
                    "title": "Target Name",
                    "description": "Name of person or company for entity extraction."
                },
                {
                    "name": "output_language",
                    "type": {
                        "name": "enum",
                        "values": [
                            "English",
                            "Slovak"
                        ]
                    },
                    "optional": true,
                    "title": "Output Language",
                    "description": "Language for generated output.",
                    "default": "English"
                },
                {
                    "name": "country",
                    "type": {
                        "name": "enum",
                        "values": [
                            "usa",
                            "australia",
                            "new_zealand",
                            "great_britain",
                            "germany",
                            "czechia",
                            "slovakia",
                            "italy",
                            "austria",
                            "belgium",
                            "bulgaria",
                            "croatia",
                            "cyprus",
                            "denmark",
                            "estonia",
                            "finland",
                            "france",
                            "greece",
                            "hungary",
                            "ireland",
                            "latvia",
                            "lithuania",
                            "luxembourg",
                            "malta",
                            "netherlands",
                            "poland",
                            "portugal",
                            "romania",
                            "slovenia",
                            "spain",
                            "sweden"
                        ]
                    },
                    "optional": true,
                    "title": "Country",
                    "description": "Country of origin of websites used for screening. Increases accuracy."
                },
                {
                    "name": "force_recreate",
                    "type": "boolean",
                    "optional": true,
                    "title": "Force Recreate",
                    "description": "Bypass cache and refresh all response parts.",
                    "default": false
                }
            ]
        }
    ],
    "settings": [
        {
            "name": "api_key",
            "type": "string",
            "title": "Adversea API Key",
            "description": "Your Adversea API key (X-Adversea-Api-Key header).",
            "required": true,
            "default": null
        }
    ],
    "metrics": [
        {
            "name": "remaining_credit",
            "type": "string",
            "title": "Remaining Credit",
            "description": "Current Adversea account credit in EUR, refreshed on each plugin run."
        }
    ]
}