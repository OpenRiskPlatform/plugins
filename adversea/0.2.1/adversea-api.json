        "/screening/topic-report": {
            "get": {
                "tags": [
                    "Adversea global screening services"
                ],
                "description": "Performs a complex screening of an target based on publicly available internet data. Resulting report contains multiple topics. These include:\n\n- basic_check - general information about screened target.\n- political_activity - political activity of the screened target. Can be used to complement PEP checking\n- legal_issues - information about court cases, fines and similar information about screened target.\n- corruption - checks whether or not the screened target is associated with corruption cases.\n- financial_crime - checks whether or not the screened target is associated with financial crimes, such as fraud, embezzlement etc.\n- violent_crime - checks whether or not the screened target is associated with violent crimes.\n- sex_crime - checks whether or not the screened target is associated with sexual crimes.\n",
                "operationId": "getTopicReport",
                "parameters": [
                    {
                        "name": "X-Adversea-Api-Key",
                        "in": "header",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
