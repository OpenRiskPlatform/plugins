{
    "openapi": "3.0.1",
    "info": {
        "title": "Swagger documentation",
        "description": "This is an API documentation for services provided by adversea.com.\n\nYou can use this API and the data it provides to perform screening / background checks for people or companies.\n\nEvery endpoint requires an API key. To obtain an API key, please visit your profile page on https://adversea.com/profile and generate an API key for yourself.\n\n\nYour API key uses will not be decreased by responses that are 4xx or 5xx",
        "contact": {
            "name": "Adversea",
            "url": "https://adversea.com",
            "email": "info@adversea.com"
        }
    },
    "servers": [
        {
            "url": "/api/gateway-service",
            "description": "Deployed adversea API"
        }
    ],
    "tags": [
        {
            "name": "Adversea global screening services",
            "description": "Services designed to work with global data."
        }
    ],
    "paths": {
        "/screening/unit-analysis/text": {
            "get": {
                "tags": [
                    "Adversea global screening services"
                ],
                "description": "Analyze results from various search engines. Includes results from Google, Bing and other popular search engines.\n\nCan be reduced to analyze only internet media with the boolean flag mediaOnly.\n\nThe result is in a form of simple and concise human readable text analysis for each analyzed URL.\n",
                "operationId": "getUnitAnalysisText",
                "parameters": [
                    {
                        "name": "X-Adversea-Api-Key",
                        "in": "header",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "targetName",
                        "in": "query",
                        "description": "Name of the screening entity. Can't be number or a phone number.",
                        "required": true,
                        "schema": {
                            "maxLength": 50,
                            "minLength": 0,
                            "pattern": "^(?![0-9+()\\-\\s]+$)(?!.*\\d{7,}).*$",
                            "type": "string"
                        }
                    },
                    {
                        "name": "country",
                        "in": "query",
                        "description": "Country of origin of websites used for screening. Increases accuracy.\n\nIf you do not find a country of origin that would cover your needs, please contact us on info@adversea.com\n",
                        "required": false,
                        "schema": {
                            "type": "string",
                            "enum": [
                                "usa",
                                "australia",
                                "new_zealand",
                                "great_britain",
                                "germany",
                                "czechia",
                                "slovakia",
                                "italy",
                                "austria",
                                "belgium",
                                "bulgaria",
                                "croatia",
                                "cyprus",
                                "denmark",
                                "estonia",
                                "finland",
                                "france",
                                "greece",
                                "hungary",
                                "ireland",
                                "latvia",
                                "lithuania",
                                "luxembourg",
                                "malta",
                                "netherlands",
                                "poland",
                                "portugal",
                                "romania",
                                "slovenia",
                                "spain",
                                "sweden"
                            ]
                        }
                    },
                    {
                        "name": "outputLanguage",
                        "in": "query",
                        "description": "Output language of the generated data.",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "enum": [
                                "English",
                                "Slovak"
                            ]
                        }
                    },
                    {
                        "name": "mediaOnly",
                        "in": "query",
                        "description": "Focus the analysis only on internet media. Useful if you want to focus on adverse media screening",
                        "required": false,
                        "schema": {
                            "type": "boolean",
                            "default": false
                        }
                    },
                    {
                        "name": "forceRecreate",
                        "in": "query",
                        "description": "Force adversea to update all parts of the response with the latest data and bypass cache. Requests with this parameter set to true are generally slower but work with the latest data.",
                        "required": false,
                        "schema": {
                            "type": "boolean",
                            "default": false
                        }
                    }
                ],
                "responses": {
                    "500": {
                        "description": "Adversea server error. In case of this response, don't hesitate to contact us for help.",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/GenericError"
                                }
                            }
                        }
                    },
                    "200": {
                        "description": "Successfully perform the request and receive a data object.",
                        "content": {
                            "*/*": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "$ref": "#/components/schemas/UnitAnalysisText"
                                    }
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Bad request, most likely incorrect input.",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/GenericError"
                                }
                            }
                        }
                    }
                }
            }
        },
