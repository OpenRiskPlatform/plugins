        "/screening/pepSanctions": {
            "get": {
                "tags": [
                    "Adversea global screening services"
                ],
                "description": "Check if a target is tracked as either a sanctioned target or a politically exposed person.",
                "operationId": "getPepServiceResponse",
                "parameters": [
                    {
                        "name": "X-Adversea-Api-Key",
                        "in": "header",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "targetName",
                        "in": "query",
                        "description": "Name of a screening entity. Can't be number or a phone number.",
                        "required": true,
                        "schema": {
                            "maxLength": 50,
                            "minLength": 0,
                            "pattern": "^(?![0-9+()\\-\\s]+$)(?!.*\\d{7,}).*$",
                            "type": "string"
                        }
                    },
                    {
                        "name": "forceRecreate",
                        "in": "query",
                        "description": "Force adversea to update all parts of the response with the latest data and bypass cache.",
                        "required": false,
                        "schema": {
                            "type": "boolean",
                            "default": false
                        }
                    }
                ],
                "responses": {
                    "500": {
                        "description": "Adversea server error. In case of this response, don't hesitate to contact us for help.",
