    "components": {
        "schemas": {
            "GenericError": {
                "type": "object",
                "properties": {
                    "message": {
                        "type": "string"
                    }
                }
            },
            "UnitAnalysisText": {
                "type": "object",
                "properties": {
                    "url": {
                        "type": "string",
                        "example": "https://reputable-source.com/article/s4dg8s1w8"
                    },
                    "title": {
                        "type": "string",
                        "example": "You wont believe what John did in 1995"
                    },
                    "analysis": {
                        "type": "string"
                    },
                    "adverseActivityDetected": {
                        "type": "boolean",
                        "description": "Determines whether or not we detected adverse activity of the analyzed target in result text. Useful for automated checks."
                    }
                }
            },
            "UnitAnalysisClaim": {
                "type": "object",
                "properties": {
                    "url": {
                        "type": "string",
                        "example": "https://reputable-source.com/article/s4dg8s1w8"
                    },
                    "title": {
                        "type": "string",
                        "example": "You wont believe what John did in 1995"
                    },
                    "claims": {
                        "type": "array",
                        "items": {
                            "type": "string"
                        }
                    },
                    "adverseActivityDetected": {
                        "type": "boolean",
                        "description": "Determines whether or not we detected adverse activity of the analyzed target in result text. Useful for automated checks."
                    }
                }
            },
            "SingleTopicResponse": {
                "type": "object",
                "properties": {
                    "targetName": {
                        "type": "string",
                        "example": "John Doe"
                    },
                    "topicId": {
                        "type": "string",
                        "example": "basic_check",
                        "enum": [
                            "basic_check",
                            "political_activity",
                            "legal_issues",
                            "corruption",
                            "financial_crime",
                            "violent_crime",
                            "sex_crime"
                        ]
                    },
                    "result": {
                        "type": "string",
                        "example": "According to the provided sources, John Doe is a mayor and an ex politician in Europe."
                    },
                    "adverseActivityDetected": {
                        "type": "boolean",
                        "description": "Determines whether or not we detected adverse activity of the analyzed target in result text. Useful for automated checks."
                    },
                    "sources": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/Source"
                        }
                    }
                }
            },
            "Source": {
                "type": "object",
                "properties": {
                    "title": {
                        "type": "string",
                        "example": "Interesting article title"
                    },
                    "url": {
                        "type": "string",
                        "example": "https://news-source.com/article-about-john"
                    }
                }
            },
            "EntityInfo": {
                "type": "object",
                "properties": {
                    "aliases": {
                        "type": "array",
                        "items": {
                            "type": "string"
                        }
                    },
                    "addresses": {
                        "type": "string"
                    },
                    "birth_date": {
                        "type": "string"
                    },
                    "countries_full": {
                        "type": "array",
                        "items": {
                            "type": "string"
                        }
                    },
                    "data_source": {
                        "type": "array",
                        "items": {
                            "type": "string"
                        }
                    },
                    "emails": {
                        "type": "string"
                    },
                    "schema": {
                        "type": "string"
                    },
                    "name": {
                        "type": "string"
                    },
                    "name_ascii": {
                        "type": "string"
                    },
                    "phones": {
                        "type": "string"
                    }
                }
            },
            "Pep": {
                "type": "object",
                "properties": {
                    "dataset": {
                        "type": "array",
                        "items": {
                            "type": "string"
                        }
                    },
                    "municipality": {
                        "type": "string"
                    },
                    "state_companies": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/StateCompanies"
                        }
                    }
                }
            },
            "PepServiceResponse": {
                "required": [
                    "entity_info",
                    "sanctions"
                ],
                "type": "object",
                "properties": {
                    "pep": {
                        "$ref": "#/components/schemas/Pep"
                    },
                    "sanctions": {
                        "$ref": "#/components/schemas/Sanctions"
                    },
                    "entity_info": {
                        "$ref": "#/components/schemas/EntityInfo"
                    },
                    "query": {
                        "type": "string"
                    }
                }
            },
            "Sanctions": {
                "type": "object",
                "properties": {
                    "description": {
                        "type": "object",
                        "additionalProperties": {
                            "type": "string"
                        }
                    },
                    "dataset": {
                        "type": "array",
                        "items": {
                            "type": "string"
                        }
                    }
                }
            },
            "StateCompanies": {
                "type": "object",
                "properties": {
                    "address": {
                        "type": "string"
                    },
                    "company_ico": {
                        "type": "integer",
                        "format": "int32"
                    },
                    "company_name": {
                        "type": "string"
                    },
                    "effective_from": {
                        "type": "string"
                    },
                    "effective_to": {
                        "type": "string"
                    },
                    "position": {
                        "type": "string"
                    }
                }
            }
        }
    }
}
